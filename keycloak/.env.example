# Keycloak alap konfig
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://<RAILWAY_POSTGRES_HOST>:<PORT>/<DB_NAME>
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=

# Keycloak admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# Keycloak hostname (Railway public domain)
KC_HOSTNAME=<your-keycloak-service>.up.railway.app
KC_HOSTNAME_STRICT=true
KC_HTTP_ENABLED=true
KC_PROXY_HEADERS=xforwarded

# vymalo webhook provider konfig
# Az esemenyek, amikre kuldjon webhookot (vesszővel elvalasztva)
WEBHOOK_HTTP_BASE_URL=https://<your-sync-backend>.up.railway.app
WEBHOOK_HTTP_SHARED_SECRET=<generate-strong-random-secret>
# Esemeny tipusok: LOGIN, REGISTER, UPDATE_PROFILE, stb.
WEBHOOK_HTTP_EVENT_TYPES=LOGIN,REGISTER,UPDATE_PROFILE
